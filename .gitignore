## Ignore Visual Studio temporary files, build results, and
## files generated by common Visual Studio/.NET/C++ tooling.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.rsuser

# Visual Studio workspace/cache
.vs/
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
ARM64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
artifacts/
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Local SDK/NuGet caches used by Kit build scripts
.dotnet/
.nuget-appdata/
.nuget-cache/
.nuget-packages/

# NuGet packages
*.nupkg
/packages/
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# Logs, traces, dumps, and binary logs
*.log
*.binlog
*.dmp
*.etl
*.e2e
*.svclog
*.trx

# Files built by Visual Studio/MSBuild
*_i.c
*_p.c
*_i.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.vspscc
*.vssscc
*.pidb
*.scc
.builds

# MSBuild preprocessed/project diagnostic output
*.pp.vcxproj
*.pp.csproj
*.pp.props
*.pp.targets
*.pp.xml

# Generated source and generated assets
Generated/
Generated\ Files/
Generated_Code/
**/*.HTMLClient/GeneratedArtifacts
**/*.DesktopClient/GeneratedArtifacts
**/*.DesktopClient/ModelManifest.xml
**/*.Server/GeneratedArtifacts
**/*.Server/ModelManifest.xml
_Pvt_Extensions

# Test and coverage output
*.VisualState.xml
TestResult.xml
BenchmarkDotNet.Artifacts/
*.coverage
*.coveragexml
FakesAssemblies/
OpenCover/

# Profiling and analysis output
*.psess
*.vsp
*.vspx
*.sap
*.nvuser

# Common IDE/add-in output
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/
*.sln.iml
.JustCode
_TeamCity*
*.dotCover
.axoCover/*
!.axoCover/settings.json
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
*.mm.*
AutoTest.Net/
.cr/
.mfractor/
*.GhostDoc.xml
*.tss
*.jmconfig

# Node/web tooling
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.sass-cache/
.ntvs_analysis.dat
ClientBin/

# Python tooling
__pycache__/
*.pyc

# Publish/package output
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.msix
*.msixbundle
*.wixpdb

# Azure/emulator and misc generated files
csx/
*.build.csdef
ecf/
rcf/
ASALocalRun/

# SQL Server/local database files
*.mdf
*.ldf
*.ndf
*.dbmdl
*.dbproj.schemaview
*.jfm

# Upgrade/backup output
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# Temporary and backup files
~$*
*~
*.tmp
*.bak
*.orig

# Secrets/signing material
*.pfx
*.publishsettings

# PowerToys-specific temporary outputs
src/settings/settings-html/200.html
src/settings/settings-html/404.html
src/common/Telemetry/*.etl
/src/settings-ui/Settings.UI/Assets/Settings/search.index.json
/MSBuildCacheLogs/
/src/modules/previewpane/SvgThumbnailProvider/$(SolutionDir)$(Platform)/$(Configuration)/modules/FileExplorerPreview/SvgThumbnailProvider.xml
/src/modules/powerrename/ui/RCa24464
/src/modules/powerrename/ui/RCb24464

# Do not ignore MergeModules build folders that are intentionally versioned upstream.
!**/MergeModules/Release/
!**/MergeModules/Debug/

# Local-only agent/tool state
**/.claude/settings.local.json
.copilot
.squad
.squad-workstream
.github/agents/**squad**.md
.github/workflows/**squad**.yml
