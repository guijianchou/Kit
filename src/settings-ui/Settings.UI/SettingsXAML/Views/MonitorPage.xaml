<?xml version="1.0" encoding="utf-8" ?>
<local:NavigablePage
    x:Class="Microsoft.PowerToys.Settings.UI.Views.MonitorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.PowerToys.Settings.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Microsoft.PowerToys.Settings.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tkcontrols="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:viewModels="using:Microsoft.PowerToys.Settings.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:MonitorViewModel}"
    AutomationProperties.LandmarkType="Main"
    mc:Ignorable="d">

    <controls:SettingsPageControl
        x:Uid="Monitor"
        IsTabStop="False"
        ModuleImageSource="ms-appx:///Assets/Settings/Modules/PT.png">
        <controls:SettingsPageControl.ModuleContent>
            <StackPanel ChildrenTransitions="{StaticResource SettingsCardsAnimations}" Orientation="Vertical">
                <controls:GPOInfoControl ShowWarning="{x:Bind ViewModel.IsEnabledGpoConfigured, Mode=OneWay}">
                    <tkcontrols:SettingsCard
                        x:Uid="Monitor_EnableSettingsCard"
                        HeaderIcon="{ui:BitmapIcon Source=/Assets/Settings/Icons/PowerToys.png}"
                        IsEnabled="{x:Bind ViewModel.IsEnabledGpoConfigured, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                        <ToggleSwitch AutomationProperties.AutomationId="Toggle_Monitor" IsOn="{x:Bind ViewModel.IsEnabled, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>
                </controls:GPOInfoControl>

                <controls:SettingsGroup x:Uid="Monitor_ScanSettingsGroup" IsEnabled="{x:Bind ViewModel.IsEnabled, Mode=OneWay}">
                    <tkcontrols:SettingsCard
                        x:Uid="Monitor_ScanNowSettingsCard"
                        HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}"
                        HorizontalContentAlignment="Stretch">
                        <Grid MinWidth="{StaticResource SettingActionControlMinWidth}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.IsManualScanProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ProgressBar
                                    x:Name="Monitor_ManualScanProgressBar"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="ManualScanProgress_Monitor"
                                    IsIndeterminate="{x:Bind ViewModel.IsManualScanProgressIndeterminate, Mode=OneWay}"
                                    Maximum="100"
                                    Minimum="1"
                                    Value="{x:Bind ViewModel.ManualScanProgressValue, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="ManualScanProgressText_Monitor"
                                    Text="{x:Bind ViewModel.ManualScanProgressText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,4,0,0"
                                    AutomationProperties.AutomationId="ManualScanProgressDetail_Monitor"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.ManualScanProgressDetail, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <Button
                                Grid.Column="1"
                                x:Uid="Monitor_ScanNowButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                AutomationProperties.AutomationId="ScanNow_Monitor"
                                Click="ScanNow_Click"
                                Style="{StaticResource AccentButtonStyle}" />
                        </Grid>
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_OrganizeDownloadsSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}">
                        <ToggleSwitch AutomationProperties.AutomationId="OrganizeDownloads_Monitor" IsOn="{x:Bind ViewModel.OrganizeDownloads, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_CleanInstallersSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE74D;}">
                        <ToggleSwitch AutomationProperties.AutomationId="CleanInstallers_Monitor" IsOn="{x:Bind ViewModel.CleanInstallers, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_RunInBackgroundSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE823;}">
                        <ToggleSwitch AutomationProperties.AutomationId="RunInBackground_Monitor" IsOn="{x:Bind ViewModel.RunInBackground, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_DownloadsPathSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}">
                        <Grid MinWidth="{StaticResource SettingActionControlMinWidth}" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                AutomationProperties.AutomationId="DownloadsPathDisplay_Monitor"
                                Text="{x:Bind ViewModel.DownloadsPathDisplay, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <Button
                                x:Uid="Monitor_SelectDownloadsFolderButton"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="SelectDownloadsFolder_Monitor"
                                Click="BrowseDownloadsFolder_Click" />
                        </Grid>
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_CsvFileNameSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE8A5;}">
                        <TextBox
                            MinWidth="{StaticResource SettingActionControlMinWidth}"
                            AutomationProperties.AutomationId="CsvFileName_Monitor"
                            Text="{x:Bind ViewModel.CsvFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_ScanIntervalSeconds" HeaderIcon="{ui:FontIcon Glyph=&#xE823;}">
                        <NumberBox
                            MinWidth="{StaticResource SettingActionControlMinWidth}"
                            AutomationProperties.AutomationId="ScanIntervalSeconds_Monitor"
                            LargeChange="600"
                            Minimum="60"
                            SmallChange="60"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.ScanIntervalSeconds, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_MaxFileSizeMegabytes" HeaderIcon="{ui:FontIcon Glyph=&#xE8D4;}">
                        <NumberBox
                            MinWidth="{StaticResource SettingActionControlMinWidth}"
                            AutomationProperties.AutomationId="MaxFileSizeMegabytes_Monitor"
                            LargeChange="100"
                            Minimum="1"
                            SmallChange="10"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.MaxFileSizeMegabytes, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>

                    <tkcontrols:SettingsCard x:Uid="Monitor_HashAlgorithmSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE950;}">
                        <ComboBox
                            MinWidth="{StaticResource SettingActionControlMinWidth}"
                            AutomationProperties.AutomationId="HashAlgorithmSelector_Monitor"
                            SelectedValue="{x:Bind ViewModel.HashAlgorithm, Mode=TwoWay}"
                            SelectedValuePath="Tag">
                            <ComboBoxItem Content="SHA1" Tag="SHA1" />
                            <ComboBoxItem Content="MD5" Tag="MD5" />
                            <ComboBoxItem Content="SHA256" Tag="SHA256" />
                            <ComboBoxItem Content="SHA512" Tag="SHA512" />
                        </ComboBox>
                    </tkcontrols:SettingsCard>
                </controls:SettingsGroup>

                <controls:SettingsGroup x:Uid="Monitor_BehaviorSettingsGroup" IsEnabled="{x:Bind ViewModel.IsEnabled, Mode=OneWay}">
                    <tkcontrols:SettingsCard x:Uid="Monitor_UseIncrementalHashingSettingsCard" HeaderIcon="{ui:FontIcon Glyph=&#xE895;}">
                        <ToggleSwitch AutomationProperties.AutomationId="UseIncrementalHashing_Monitor" IsOn="{x:Bind ViewModel.UseIncrementalHashing, Mode=TwoWay}" />
                    </tkcontrols:SettingsCard>
                </controls:SettingsGroup>
            </StackPanel>
        </controls:SettingsPageControl.ModuleContent>

        <controls:SettingsPageControl.PrimaryLinks>
            <controls:PageLink x:Uid="LearnMore_Monitor" Link="https://github.com/microsoft/PowerToys" />
        </controls:SettingsPageControl.PrimaryLinks>
    </controls:SettingsPageControl>
</local:NavigablePage>
